rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner() {
      return existing().ownerId == request.auth.uid;
    }

    function isCollaborator() {
      return request.auth.uid in existing().collaboratorIds;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['ownerId', 'createdAt', 'updatedAt'])
        && data.ownerId == request.auth.uid
        && data.ownerId is string && data.ownerId.size() <= 128
        && ( !('collaboratorIds' in data) || (data.collaboratorIds is list && data.collaboratorIds.size() <= 20) )
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /trips/{tripId} {
      allow read: if isValidId(tripId) && isSignedIn();
      
      allow create: if isValidId(tripId) && isSignedIn() 
        && isValidTrip(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isValidId(tripId) && isSignedIn() 
        && isValidTrip(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().ownerId == existing().ownerId;
        
      allow delete: if isValidId(tripId) && isSignedIn() && isOwner();
    }
  }
}
